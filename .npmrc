# npm 동작 보강 — 공급망 리스크 축소.

# 새 패키지 설치 시 ^ 범위가 아닌 정확한 버전으로 lock.
# package-lock.json 만 의존하지 않고 package.json 도 핀닝 상태 유지.
save-exact=true

# npm audit 가 high 이상 취약점에서만 실패하도록 (low/medium 은 정보용).
audit-level=high

# ignore-scripts 는 의도적으로 활성화하지 않음.
# supabase CLI 와 @tauri-apps/cli 가 postinstall 로 네이티브 바이너리를 받기 때문.
# 신규 의존성 추가 시 install script 가 신뢰 가능한지 매번 검토할 것.
