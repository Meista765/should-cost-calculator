{
  "name": "should-cost-calculator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "판금/프레스 3D 설계 변경에 따른 가격 AS-IS, TO-BE 계산기 (오프라인 .exe + 사내 웹)",
  "scripts": {
    "encrypt:data": "node scripts/encrypt-data.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild:tauri": "npm run encrypt:data && node scripts/copy-bundle-to-tauri.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run prebuild:tauri && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supabase": "^2.98.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
